POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me-to-a-long-random-postgres-password
POSTGRES_DB=portal
DATABASE_URL=postgres://portal:change-me-to-a-long-random-postgres-password@postgres:5432/portal

CONNECTOR_SECRET_KEY=replace-me-with-at-least-32-random-bytes
AUTH_TOKEN_TTL_SECONDS=86400
AUTH_MAX_ACTIVE_SESSIONS_PER_USER=20
AUTH_COOKIE_SECURE=true
AUTH_LOGIN_MAX_FAILURES=5
AUTH_LOGIN_ACCOUNT_MAX_FAILURES=50
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_LOCKOUT_SECONDS=900
AUTH_PASSWORD_LOGIN_ENABLED=true
AUTH_ENTRA_ENABLED=false

# Microsoft Entra ID sign-in. Keep password login enabled for a staged rollout
# and break-glass access. When AUTH_ENTRA_ENABLED=true, replace and uncomment
# every required value below. Do not reuse CONNECTOR_SECRET_KEY for either
# Entra secret. The current server uses client-secret authentication for the
# authorization-code exchange.
# AUTH_ENTRA_TENANT_ID=<tenant-guid>
# AUTH_ENTRA_CLIENT_ID=<application-client-guid>
# AUTH_ENTRA_CLIENT_SECRET=<client-secret-from-approved-secret-store>
# AUTH_ENTRA_REDIRECT_URI=https://portal.internal.example/auth/entra/callback
# AUTH_OIDC_TRANSACTION_KEY=<at-least-32-high-entropy-bytes>

# Optional tenant-specific endpoint overrides. Leave these unset for Microsoft
# defaults; production overrides must still be HTTPS.
# AUTH_ENTRA_ISSUER=https://login.microsoftonline.com/<tenant-guid>/v2.0
# AUTH_ENTRA_AUTHORIZATION_URL=https://login.microsoftonline.com/<tenant-guid>/oauth2/v2.0/authorize
# AUTH_ENTRA_TOKEN_URL=https://login.microsoftonline.com/<tenant-guid>/oauth2/v2.0/token
# AUTH_ENTRA_JWKS_URL=https://login.microsoftonline.com/<tenant-guid>/discovery/v2.0/keys

AUTH_ENTRA_JIT_PROVISIONING=false
# Required in production when JIT provisioning is true:
# AUTH_ENTRA_REQUIRED_ROLE=Portal.Member
AUTH_OIDC_TRANSACTION_TTL_SECONDS=600
AUTH_ENTRA_JWKS_CACHE_SECONDS=300
AUTH_ENTRA_CLOCK_SKEW_SECONDS=120

PORT=8000
ROCKET_PORT=8000
# Enforced by the production server/Compose so OIDC callback code and state
# never appear in Rocket's normal request log.
ROCKET_LOG_LEVEL=critical

CONNECTOR_WORKER_ENABLED=true
CONNECTOR_SCHEDULER_ENABLED=true
CONNECTOR_WORKER_POLL_MS=500
CONNECTOR_WORKER_HEARTBEAT_INTERVAL_SECONDS=15
CONNECTOR_WORKER_STALE_AFTER_SECONDS=45
CONNECTOR_RUN_LEASE_SECONDS=60
CONNECTOR_RUN_LEASE_RENEW_INTERVAL_SECONDS=15
CONNECTOR_RUN_MAX_ATTEMPTS=3
CONNECTOR_RUN_RETRY_BASE_SECONDS=5
CONNECTOR_RUN_RETRY_MAX_SECONDS=300
CONNECTOR_HEALTH_RETENTION_DAYS=30
CONNECTOR_RUN_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
CONNECTOR_RETENTION_CLEANUP_INTERVAL_SECONDS=3600

# Optional one-time admin seed:
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=change-me-to-a-long-random-admin-password
# SEED_ADMIN_ROLES=admin,member
